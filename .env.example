# Prisma runtime URL (use Supabase pooler URL in production/serverless)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# Prisma direct URL (used by Prisma Migrate/CLI)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

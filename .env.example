# Prisma datasource URL (use Supabase pooler URL in production/serverless)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# Auth.js secret (minimum 32 characters)
AUTH_SECRET="replace-with-a-strong-random-secret"

# Required when running behind proxies / Vercel / local reverse hosts
AUTH_TRUST_HOST="true"

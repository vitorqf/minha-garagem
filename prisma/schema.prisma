generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  vehicles     Vehicle[]
}

model Vehicle {
  id        String   @id @default(cuid())
  ownerId   String
  nickname  String
  brand     String
  model     String
  plate     String?
  year      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  expenses  Expense[]

  @@unique([id, ownerId])
  @@unique([ownerId, plate])
  @@index([ownerId, createdAt])
}

enum ExpenseCategory {
  fuel
  parts
  service
}

model Expense {
  id         String          @id @default(cuid())
  ownerId    String
  vehicleId  String
  expenseDate DateTime
  category   ExpenseCategory
  amountCents Int
  mileage    Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId, ownerId], references: [id, ownerId], onDelete: Restrict, onUpdate: Cascade)

  @@index([ownerId, expenseDate])
  @@index([ownerId, vehicleId, expenseDate])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id        String   @id @default(cuid())
  ownerId   String
  nickname  String
  brand     String
  model     String
  plate     String?
  year      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, plate])
  @@index([ownerId, createdAt])
}
